ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
DEEPSEEK_API_KEY=
BRAVE_API_KEY=

TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_IDS=

DB_PATH=./randy.sqlite
SESSION_COST_CAP_USD=25.0
PER_MODEL_COST_CAP_USD=2.0

# Web dashboard bind. Use 0.0.0.0 on a LAN server, 127.0.0.1 on dev.
WEB_HOST=127.0.0.1
WEB_PORT=8000

FACILITATOR_MODEL=gemini-3-pro-preview
EXPERT_ANTHROPIC_MODEL=claude-sonnet-4-6
EXPERT_OPENAI_MODEL=gpt-5.5
EXPERT_DEEPSEEK_MODEL=deepseek-v4-pro

# Researcher (cheap Flash-tier; runs before R1 to ground experts in real data)
RESEARCHER_MODEL=gemini-flash-latest
RESEARCH_TIMEOUT_SECONDS=30
RESEARCH_MAX_TOPICS=4
RESEARCH_MAX_RESULTS_PER_TOPIC=3
RESEARCH_DIR=./data/research
